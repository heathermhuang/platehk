{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "platehk",
  "main": "cloudflare-worker/src/index.mjs",
  "compatibility_date": "2026-03-24",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "plate.hk/*",
      "zone_name": "plate.hk"
    },
    {
      "pattern": "www.plate.hk/*",
      "zone_name": "plate.hk"
    },
    {
      "pattern": "pvrm.hk/*",
      "zone_name": "pvrm.hk"
    }
  ],
  "assets": {
    "directory": ".tmp/cloudflare-public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "vars": {
    "APP_ENV": "production",
    "OPENAI_BASE_URL": "https://api.openai.com/v1",
    "OPENAI_VISION_MODEL": "gpt-4.1-mini",
    "OPENAI_TIMEOUT_SECONDS": "20"
  }
}
